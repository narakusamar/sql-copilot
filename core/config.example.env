# API 配置
API_KEY=your-api-key
BASE_URL=https://api.deepseek.com/v1
MODEL=deepseek-chat

# 数据库配置
DB_TYPE=sqlite
DB_PATH=superstore.db
# MySQL / PostgreSQL 配置（DB_TYPE=mysql 或 postgresql 时生效）
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=superstore

# SQL 修复最大重试次数
MAX_RETRIES=3

# HuggingFace 镜像（国内用户建议）
HF_ENDPOINT=https://hf-mirror.com
